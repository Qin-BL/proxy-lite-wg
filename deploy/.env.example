APP_ADDR=0.0.0.0:8080
APP_DB_PATH=/app/data/proxy-lite-control.db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET_PATH=/app/data/session_secret
ADMIN_SESSION_TTL_HOURS=12

PUBLIC_HOST=test-api.hiring.evismart.com
PUBLIC_PORT=443
VLESS_WS_PATH=/_ws_change_me

XRAY_CONFIG_PATH=/app/runtime/config.json
XRAY_CONTAINER_NAME=proxy-lite-wg-xray
XRAY_INBOUND_PORT=10000
XRAY_LOG_LEVEL=warning
DOCKER_SOCKET_PATH=/var/run/docker.sock
